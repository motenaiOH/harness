{
  "name": "@app/web",
  "version": "0.1.0",
  "private": true,
  "//": "Web is a thin Next.js channel: it authenticates the user and acts as a server-side proxy to the API. It holds NO business logic — the Bearer is minted and attached server-side and never reaches the browser. Scope is @app/* (rename to your own scope); it imports the COMPILED dist of @app/contracts, so that package must be built first.",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run"
  },
  "dependencies": {
    "@app/contracts": "workspace:*",
    "@opentelemetry/api": "^1.9.0",
    "@vercel/otel": "^2.1.2",
    "jose": "^5.9.6",
    "next": "^15.1.0",
    "next-auth": "beta",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@app/eslint-config": "workspace:*",
    "@app/tsconfig": "workspace:*",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.17.0",
    "jsdom": "^26.1.0",
    "typescript": "^5.7.2",
    "vitest": "^4.1.8"
  }
}
