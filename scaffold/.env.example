# ─────────────────────────────────────────────────────────────
# <App> harness — environment variables (copy to .env)
# ─────────────────────────────────────────────────────────────
#
# This file is the env-contract surface. DISCIPLINE: when you add an env var it
# moves in LOCKSTEP with compose.yaml (+ overlays), the Helm values/configmap, and
# the Secret template — a partial change passes locally but breaks another
# environment silently.
#
# Two-secret auth ("Architecture A"), do not conflate:
#   AUTH_SECRET     — encrypts the Auth.js session cookie (browser-facing).
#   AUTH_API_SECRET — shared HS256 secret between web and the API. The web app mints
#                     a short-lived API JWT server-side; the API verifies it (iss/aud
#                     pinned, HS256). The Bearer token never reaches the browser.

# --- Auth.js (frontend session encryption) ---
# openssl rand -base64 48
AUTH_SECRET=dev-only-change-me-auth-secret-0000000000000000

# --- Shared HS256 API secret (MUST match on web and the API). Min 44 chars (base64 of
#     32 bytes). openssl rand -base64 32
AUTH_API_SECRET=dev-only-change-me-api-secret-00000000000000000
JWT_ISSUER=app-web
JWT_AUDIENCE=app-api

# --- CORS (API) ---
# Comma-separated EXPLICIT allowlist of origins allowed to call the API with
# credentials (a denylist always forgets something).
CORS_ORIGIN=http://localhost:3000

# --- Web -> API ---
NEST_API_URL=http://localhost:3001
NEXTAUTH_URL=http://localhost:3000

# --- Demo credentials (Credentials provider; seeded by the seed one-shot) ---
DEMO_USER_EMAIL=demo@app.dev
DEMO_USER_PASSWORD=demo1234

# --- API ports ---
PORT=3001

# --- Rate limiting (API) ---
# TTL window in ms (default 60000). Max requests per IP per window (default 100,
# the secure prod value). Raise for local/e2e where the suite drives one IP.
# THROTTLE_TTL=60000
# THROTTLE_LIMIT=100
# Strict brute-force limit for the login route (default 5 per window).
# THROTTLE_LOGIN_LIMIT=5

# --- Postgres (domain DB) ---
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=app
DATABASE_URL=postgres://app:app@localhost:5432/app

# --- Redis (cache) ---
REDIS_PASSWORD=app
REDIS_URL=redis://:app@localhost:6379

# --- RabbitMQ (broker) ---
RABBITMQ_DEFAULT_USER=app
RABBITMQ_DEFAULT_PASS=app
RABBITMQ_URI=amqp://app:app@localhost:5672

# --- Observability (OTLP HTTP) ---
# Telemetry is best-effort: leave EMPTY to disable (the OTel SDK no-ops; never
# gates startup). The observability overlay sets this to http://otel-lgtm:4318.
# For local non-docker dev with the LGTM stack up: http://localhost:4318
OTEL_EXPORTER_OTLP_ENDPOINT=

# --- Backoffice Grafana embed (web, optional) ---
# Base URL of Grafana for an admin dashboards page. The observability overlay sets
# this to http://localhost:3030. Must be reachable FROM THE BROWSER and allow
# embedding (GF_SECURITY_ALLOW_EMBEDDING=true). Empty => placeholder.
# GRAFANA_URL=http://localhost:3030

# --- Encrypted settings vault (AES-256-GCM) ---
# 32 bytes base64: openssl rand -base64 32
SETTINGS_SECRET_KEY=ZGV2LW9ubHktc2V0dGluZ3Mta2V5LTAwMDAwMDAwMDA=

# --- AI / LLM (optional, deterministic-first) ---
# The critical path works WITHOUT an LLM. The LLM enters behind a port and only
# "explains/organizes", never "decides". Leave the key empty for keyless/CI: the
# gateway no-ops into a deterministic fallback. Set LLM_PROVIDER=none to disable.
# Never commit a real key.
LLM_API_KEY=
LLM_PROVIDER=none
LLM_MODEL=
# LLM_MAX_TOKENS=256
# LLM_TIMEOUT_MS=10000
